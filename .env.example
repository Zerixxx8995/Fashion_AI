# Server Configurations
PORT=5000
FASTAPI_PORT=8000

# Auth (Clerk)
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Databases
DATABASE_URL=postgresql://user:password@localhost:5432/fashion_db
REDIS_URL=redis://localhost:6379/0
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# Vector Search
PINECONE_INDEX_NAME=fashion-embeddings

# Image Storage (Backblaze B2 / S3 Compatible)
B2_KEY_ID=your_b2_key_id_here
B2_APPLICATION_KEY=your_b2_application_key_here
B2_BUCKET_NAME=your_b2_bucket_name_here
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Scraping (ScraperAPI for rotating proxies)
SCRAPERAPI_KEY=your_scraperapi_key_here
